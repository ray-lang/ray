//! Testing assertions and utilities.
//!
//! Auto-imported for files containing test blocks.

/// Explicitly fails the current test with a message.
fn fail(msg: string) -> never {
    panic(msg)
}

/// Asserts that `cond` is true. On failure, fails the test.
fn assert(cond: bool) {
    if !cond {
        fail("assertion failed")
    }
}
